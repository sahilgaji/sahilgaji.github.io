---
// Progressive-disclosure block (interaction component 1 of 6, Phase 5).
// Native <details>/<summary>: zero JavaScript, keyboard- and screen-reader-
// accessible by default. Rule: reveals DEPTH only — never primary content.
interface Props {
  label: string;
}

const { label } = Astro.props;
---

<details class="disclosure">
  <summary>{label}</summary>
  <div class="content">
    <slot />
  </div>
</details>

<style>
  .disclosure {
    border-left: 2px solid var(--color-line);
    padding-left: var(--space-3);
  }
  summary {
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-accent);
    list-style: none;
    user-select: none;
  }
  summary::-webkit-details-marker {
    display: none;
  }
  summary::before {
    content: "+ ";
  }
  .disclosure[open] summary::before {
    content: "− ";
  }
  .content {
    padding-top: var(--space-2);
  }
</style>
