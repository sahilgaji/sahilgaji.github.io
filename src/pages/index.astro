---
import Base from "../layouts/Base.astro";
---

<Base title="Sahil Gaji">
  <main>
    <h1>Sahil Gaji</h1>
    <p class="role">Project Management · Digital Transformation · Germany</p>

    <div class="log" aria-label="Site status">
      <p class="entry"><span class="version">v0.1.0</span> — foundation</p>
      <p>
        This site is being built in public. It launches when it meets its
        definition of done — not a date.
      </p>
    </div>

    <p class="links">
      <a href="https://www.linkedin.com/in/sahil-gaji/">LinkedIn</a>
    </p>
  </main>

  <footer>
    <p>© 2026 Sahil Gaji · site v0.1.0</p>
  </footer>
</Base>

<style>
  main {
    max-width: var(--measure-prose);
    margin: 0 auto;
    padding: var(--space-12) var(--space-3) var(--space-8);
  }
  h1 {
    font-family: var(--font-serif);
    font-size: 2.5rem;
    font-weight: 400;
    margin: 0;
  }
  .role {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    margin: var(--space-1) 0 var(--space-8);
  }
  .log {
    border-left: 2px solid var(--color-line);
    padding-left: var(--space-3);
    font-size: 0.95rem;
  }
  .entry {
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }
  .version {
    color: var(--color-accent);
  }
  .links {
    margin-top: var(--space-8);
  }
  footer {
    max-width: var(--measure-prose);
    margin: 0 auto;
    padding: var(--space-4) var(--space-3);
    border-top: 1px solid var(--color-line);
  }
  footer p {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-ink-muted);
  }
</style>
